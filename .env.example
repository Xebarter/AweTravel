# Public Supabase (browser)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Server-only: admin transporter create/delete and email changes from /admin/transporters
# Get from Supabase Dashboard → Project Settings → API → service_role (keep secret)
SUPABASE_SERVICE_ROLE_KEY=

# Paytota (https://gate.paytota.com) — Developers section: secret key + brand id
# Optional: override API host (default https://gate.paytota.com)
# PAYTOTA_BASE_URL=https://gate.paytota.com
PAYTOTA_SECRET_KEY=
# Alias supported by some setups:
# PAYTOTA_API_KEY=
PAYTOTA_BRAND_ID=
# Webhook: PEM RSA public key (real newlines or \n). Verifies X-Signature or Signature header.
# PAYTOTA_WEBHOOK_PUBLIC_KEY="-----BEGIN PUBLIC KEY-----\n...\n-----END PUBLIC KEY-----"

# Optional Paytota behaviour (see additems.txt in repo)
# PAYTOTA_SKIP_CAPTURE=true
# PAYTOTA_PAYMENT_METHOD_WHITELIST=code1,code2
# Minimum UGX before calling Paytota (default 500). Use 0, false, or off to disable.
# PAYTOTA_MIN_PURCHASE_UGX=500
# Return URL override: full https URL or path starting with / (default /passenger/payment/return + query)
# PAYTOTA_SUCCESS_REDIRECT=
# PAYTOTA_FAILURE_REDIRECT=
# PAYTOTA_CANCEL_REDIRECT=

# Used for Paytota redirect base (set in production / Vercel)
# NEXT_PUBLIC_APP_URL=https://your-domain.com
# Register webhook in Paytota: {NEXT_PUBLIC_APP_URL}/api/payments/webhook
