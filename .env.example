# -----------------------------------------------------------------------------
# Supabase (client + middleware)
# From: https://supabase.com/dashboard/project/_/settings/api
# -----------------------------------------------------------------------------
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-public-key

# -----------------------------------------------------------------------------
# App URL (used by Paytota as callback: {APP_URL}/api/payments/webhook)
# In dev use http://localhost:3000 (or your Next.js port)
# -----------------------------------------------------------------------------
NEXT_PUBLIC_APP_URL=http://localhost:3000

# -----------------------------------------------------------------------------
# Paytota
# Server-only: never expose in NEXT_PUBLIC_* vars
# -----------------------------------------------------------------------------
PAYTOTA_API_KEY=your-paytota-secret-api-key

# Optional: verify Paytota webhooks (see app/api/payments/webhook/route.ts)
# PAYTOTA_WEBHOOK_SECRET=your-webhook-signing-secret
